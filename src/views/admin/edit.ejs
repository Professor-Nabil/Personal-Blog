<%- include('../partials/header') %>

<div class="form-container">
    <h1>Update Article</h1>
    
    <form action="/admin/edit/<%= article.id %>" method="POST">
        <div class="form-group">
            <label for="title">Article Title</label>
            <input type="text" id="title" name="title" value="<%= article.title %>" required>
        </div>

        <div class="form-group">
            <label for="date">Publishing Date</label>
            <input type="date" id="date" name="date" value="<%= article.date %>" required>
        </div>

        <div class="form-group">
            <label for="content">Content</label>
            <textarea id="content" name="content" rows="10" required><%= article.content %></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Update</button>
            <a href="/admin/dashboard" class="btn-reset">Cancel</a>
        </div>
    </form>
</div>

<%- include('../partials/footer') %>
